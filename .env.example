# Copy this file to .env and fill in your values.
# Vite bakes these into the build at compile time.
# Change them in the Settings panel at runtime (saved to localStorage).

# CNCjs server address
VITE_CNCJS_URL=http://localhost:8000

# Serial port for the CNC controller  (e.g. /dev/ttyUSB0, /dev/ttyACM0, COM3)
VITE_SERIAL_PORT=

# Baud rate
VITE_BAUDRATE=115200

# Controller type: Grbl (use for FluidNC too), Smoothie, TinyG, Marlin
VITE_CONTROLLER_TYPE=Grbl
